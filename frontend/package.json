{
  "name": "solarnext-crm-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:calpinage-shading-from-shared": "node scripts/sync-calpinage-shading-from-shared.cjs",
    "sync:near-shading-core": "node scripts/sync-calpinage-shading-from-shared.cjs",
    "verify:calpinage-shading-from-shared": "node scripts/verify-calpinage-shading-from-shared.cjs",
    "test:shading:fast": "npm run verify:calpinage-shading-from-shared && node --test calpinage/shading/__tests__/integrationShadingVolume.test.js",
    "test:shading": "npm run test:shading:fast",
    "verify:near-shading-core-public": "node scripts/verify-calpinage-shading-from-shared.cjs",
    "prebuild": "npm run build:geom3d && npm run sync:calpinage-shading-from-shared && node -e \"const fs=require('fs');const path=require('path');const p=path.join(process.cwd(),'..','backend','calpinage-legacy-assets');fs.mkdirSync(p,{recursive:true});fs.copyFileSync('calpinage/canvas-bundle.js',path.join(p,'canvas-bundle.js'));fs.copyFileSync('calpinage/map-selector-bundle.js',path.join(p,'map-selector-bundle.js'));fs.copyFileSync('calpinage/pans-bundle.js',path.join(p,'pans-bundle.js'));const p3=path.join(p,'phase3');fs.mkdirSync(p3,{recursive:true});fs.copyFileSync('calpinage/phase3/phase3Viewer.js',path.join(p3,'phase3Viewer.js'));fs.copyFileSync('calpinage/panelProjection.js',path.join(p,'panelProjection.js'));const pstate=path.join(p,'state');fs.mkdirSync(pstate,{recursive:true});fs.copyFileSync('calpinage/state/activePlacementBlock.js',path.join(pstate,'activePlacementBlock.js'));const peng=path.join(p,'engine');fs.mkdirSync(peng,{recursive:true});fs.copyFileSync('calpinage/engine/pvPlacementEngine.js',path.join(peng,'pvPlacementEngine.js'));console.log('[prebuild] bundles → backend/calpinage-legacy-assets');\"",
    "predev": "npm run prebuild",
    "dev": "vite",
    "build": "npm run sync:calpinage-shading-from-shared && (tsc || exit 0) && vite build",
    "preview": "vite preview",
    "pretest": "npm run verify:calpinage-shading-from-shared",
    "test": "node --test calpinage/shading/__tests__/*.test.js",
    "build:geom3d": "node -e \"require('fs').mkdirSync('../backend/calpinage-legacy-assets/geometry',{recursive:true});require('child_process').execSync('npx esbuild src/modules/calpinage/geometry/index.ts --bundle --format=cjs --outfile=../backend/calpinage-legacy-assets/geometry/geoEntity3D.cjs --platform=node',{stdio:'inherit'})\"",
    "test:geom3d": "tsx src/modules/calpinage/geometry/__tests__/geoEntity3D.test.ts",
    "check:design-token-debt": "node scripts/check-design-token-debt.mjs --strict",
    "check:design-system-phase3": "node scripts/check-design-system-phase3.mjs",
    "test:entity-documents-ui": "vitest run src/components/entityDocuments/__tests__/",
    "test:mairies-ui": "vitest run src/pages/mairies/__tests__/",
    "test:phase3-checklist": "vitest run src/modules/calpinage/__tests__/",
    "test:shading-parity": "vitest run src/modules/calpinage/dsmOverlay/__tests__/",
    "test:e2e": "playwright test",
    "test:stability": "playwright test -g \"Calpinage 50 cycles\"",
    "test:performance": "playwright test -g \"PERFORMANCE\"",
    "test:stress": "playwright test -g \"STRESS\"",
    "test:provider": "playwright test -g \"PROVIDER-STRESS\"",
    "test:exportjson": "playwright test -g \"EXPORT-JSON\"",
    "check:calpinage:lock": "node scripts/check-calpinage-lock.js",
    "qa:calpinage:v1": "npm run check:calpinage:lock && npm run test:stability && npm run test:stress && npm run test:provider && npm run test:exportjson && npm run test:performance",
    "test:calpinage-final-json": "vitest run src/modules/calpinage/__tests__/calpinage-final-json-validate.test.js src/modules/calpinage/__tests__/calpinage-json-reload-integrity.test.js",
    "test:canonical-hardening": "vitest run src/modules/calpinage/canonical3d/__tests__/hardening/ src/modules/calpinage/canonical3d/parsing/__tests__/parseCalpinageStateToCanonicalHouse3D.test.ts src/modules/calpinage/canonical3d/adapters/__tests__/adaptCanonicalHouseLocalToWorldScene.test.ts src/modules/calpinage/canonical3d/builders/__tests__/buildBuildingShell3D.test.ts src/modules/calpinage/canonical3d/builders/__tests__/buildRoofTopology.test.ts src/modules/calpinage/canonical3d/builders/__tests__/solveRoofPlanes.test.ts src/modules/calpinage/canonical3d/builders/__tests__/computeRoofPlaneIntersections.test.ts src/modules/calpinage/canonical3d/nearShading3d/__tests__/nearShading3d.test.ts src/modules/calpinage/canonical3d/scene/__tests__/buildSolarScene3D.test.ts src/modules/calpinage/integration/__tests__/nearShadingOfficialSelection.test.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.8",
    "@mui/x-date-pickers": "^8.27.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/three": "^0.183.1",
    "clipper-lib": "^6.4.2",
    "dayjs": "^1.11.19",
    "dompurify": "^3.2.4",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "konva": "^10.3.0",
    "ol": "^10.8.0",
    "ol-mapbox-style": "^13.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.14",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.7.0",
    "three": "^0.183.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rollup/rollup-linux-x64-gnu": "^4.40.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/connect": "^3.4.38",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "connect": "^3.7.0",
    "jsdom": "^23.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.1.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.34.9"
  }
}
