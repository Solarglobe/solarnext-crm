{
  "outputDirectory": "dist-crm",
  "redirects": [
    { "source": "/favicon.ico", "destination": "/favicon-solarnext.png" },
    { "source": "/crm.html", "destination": "/" },
    { "source": "/crm.html/:path*", "destination": "/:path*" }
  ],
  "rewrites": [
    {
      "source": "/pdf-render",
      "destination": "/pdf-render.html"
    },
    {
      "source": "/financial-quote-pdf-render",
      "destination": "/financial-quote-pdf-render.html"
    },
    {
      "source": "/calpinage-render",
      "destination": "/calpinage-render.html"
    },
    {
      "source": "/((?!assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
