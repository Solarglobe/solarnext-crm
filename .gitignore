# =============================================================================
# Solarnext CRM — hygiène Git durable
# Référence : docs/architecture/git-hygiene-solarnext.md
# =============================================================================

# --- Secrets & environnements locaux (jamais versionner) ---
# Node + Vite : ne jamais pousser de secrets
.env
.env.*
backend/.env
frontend/.env
frontend/.env.local
# Variantes explicites (redondant avec .env.* mais explicite)
.env.dev
.env.prod
.env.*.local
frontend/.env.development
frontend/.env.production

# Gabarits d'environnement (à versionner)
!.env.example
!backend/.env.example
!frontend/.env.example
# P0.2 — Feature flags Vite dev sans secrets (à versionner — source de vérité locale)
# .env.production intentionnellement absent : les vars prod sont injectées via Vercel dashboard.
# Les vrais secrets restent dans .env.dev / .env.prod (gitignorés).
!.env.development

# --- Dépendances & caches package managers ---
node_modules/
.npm/
.pnpm-store/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# --- Builds & bundles applicatifs ---
dist/
dist-crm/
build/
out/
.next/
.nuxt/

# --- Vite (artefacts locaux, hors source) ---
.vite/
frontend/vite.config.ts.timestamp-*.mjs

# --- Tests E2E / unitaires (sorties, pas les specs) ---
test-results/
playwright-report/
coverage/
.nyc_output/
playwright/.cache/
.vitest/
*.tsbuildinfo

# --- Caches & logs ---
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Temporaires & éditeurs (fichiers de secours) ---
tmp/
temp/
*.tmp
*.bak
**/.~lock*
# Word : fichiers de verrouillage Office (~$document.docx)
~$*.docx

# --- Python (backend/app, scripts utilitaires) ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

# --- IDE & préférences locales ---
.vscode/
.idea/
*.swp
*.swo
.cursor/settings.json

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Backend : stockage runtime documents (PDF, CSV conso, logos, etc.) ---
# Le code crée ces fichiers à l'exécution ; seul le dossier vide est versionné.
backend/storage/*
!backend/storage/.gitkeep

# --- Racine dépôt : extraits / dumps locaux (restauration, ne pas versionner) ---
/storage/
storage.tar.gz
storage_tar_parts/
backend/dump.sql
verify-out.json

# --- Backend : téléversements & données utilisateur locales ---
backend/backend/data/uploads/
backend/data/uploads/

# --- Backend : DSM / IGN — extracts lourds & caches (reproductibles localement) ---
backend/data/dsm/ign/extract/
backend/data/dsm/**/*.7z
backend/data/dsm/**/cache/*.asc

# --- Backend : sorties de scripts debug / audits visuels (régénérables) ---
backend/scripts/output/

# --- CP-073 : sauvegardes PostgreSQL locales (ne pas versionner les dumps) ---
backend/backups/*
!backend/backups/.gitkeep
