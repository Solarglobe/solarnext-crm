# Port du serveur (optionnel)
# PORT=3000

# Stockage fichiers (CP-032) : défaut production `/app/storage` (volume Railway). En dev local, pointer vers le dossier `backend/storage` :
# STORAGE_ROOT=./storage

# PostgreSQL (obligatoire au démarrage)
# DATABASE_URL=postgresql://user:pass@localhost:5432/smartpitch

# Migrations : en production, refus si un fichier de migration déjà appliqué diverge (checksum).
# En dev (NODE_ENV ≠ production), le manager resynchronise automatiquement migration_checksums depuis le disque.
# Pour forcer la même resynchro en prod (déconseillé sauf incident) : MIGRATION_AUTO_REPAIR_CHECKSUMS=1
# Script manuel : npm run reconcile:migration:177660-lead-sources:commit

# JWT — obligatoire : sans JWT_SECRET (ou JWT_SECRET_KEY) le serveur quitte au démarrage (process.exit).
# JWT_SECRET=changez-moi-en-dev-min-32-caracteres
# Alias supporté si JWT_SECRET absent : JWT_SECRET_KEY=
# Charger l’env via config/load-env.js (racine .env.dev puis backend/.env, sans override).

# CORS — en plus des origines **toujours** autorisées dans le code (`https://solarnext-crm.fr`, `https://api.solarnext-crm.fr`),
# lister ici les autres origines (virgules) : dev local, Vercel, etc.
# Dès qu’au moins une entrée ici est un host *.vercel.app, toutes les origines https://*.vercel.app (previews) sont autorisées automatiquement.
# Ex. : CORS_ORIGIN=http://localhost:5173,https://solarnext-crm.vercel.app
# CORS_ORIGIN=

# Playwright / PDF : `npm run build` installe Chromium. Sur Railway (Railpack), le backend/Dockerfile
# est souvent ignoré : le `postinstall` n’agit qu’avec RAILWAY_ENVIRONMENT/CI (voir scripts/postinstall-playwright.cjs).
# PDF Playwright (devis / facture / études) — OBLIGATOIRE sur Railway (backend) si NODE_ENV=production
# = URL absolue du site Vercel (même app que le CRM), sans /api. Playwright y ouvre /pdf-render, /financial-quote-pdf-render, etc.
# Sans ceci, le backend retombait sur http://localhost:5173 (invalide dans le conteneur) : aucun PDF.
# PDF_RENDERER_BASE_URL=https://solarnext-crm.vercel.app
# FRONTEND_URL= (même rôle que PDF_RENDERER_BASE_URL si l’exemple ci-dessus n’est pas défini)
# PDF_RENDER_READY_TIMEOUT=30000

# npm run test-login (optionnel)
# TEST_LOGIN_EMAIL=
# TEST_LOGIN_PASSWORD=

# Build / dev frontend (Vite) — même clé publique Maps que dans la racine `.env.example` (`VITE_GOOGLE_MAPS_API_KEY`).

# Feature flag Calpinage (routes API `/api/calpinage` uniquement) : "1", "true", "TRUE", "on" = ON, sinon OFF
# Les bundles legacy `/calpinage/*.js` sont toujours servis depuis `calpinage-legacy-assets/` avec JWT ou renderToken PDF
# (indépendamment de cette variable). En dev, Vite peut aussi servir `frontend/calpinage/**` en bypass proxy.
CALPINAGE_ENABLED=false

# Ombrage officiel serveur (parallèle) : ajoute shading_official + shading_debug au payload / data_json — n’impacte pas le moteur legacy tant que false
# USE_OFFICIAL_SHADING=false

# Persiste shading_parity_debug dans study_versions.data_json après calc (si snapshot UI fourni dans le POST)
# SHADING_PARITY_PERSIST=false

# CP-026 RBAC : "1"/"true" = bloque si permission manquante | "warn" = log + laisse passer | autre/absent = off (dev)
# En production, server.js force RBAC_ENFORCE=1 si la variable est absente.
# RBAC_ENFORCE=0
# RBAC_ENFORCE=warn
#
# SUPER_ADMIN : bypass RBAC si true/absent. Mettre false pour soumettre SUPER_ADMIN aux permissions (cas rare).
# ENABLE_SUPER_ADMIN=true
# AUDIT_SUPER_ADMIN_RBAC=true  → en plus des logs serveur, ligne audit_logs pour chaque bypass RBAC (verbeux)

# --- CP-076 Rate limiting (mémoire process ; Redis recommandé en multi-réplicas) ---
# RATE_LIMIT_STORE=memory
# REDIS_URL=redis://127.0.0.1:6379
# TRUST_PROXY=1
# RATE_LIMIT_LOGIN_MAX=5
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_USER_SENSITIVE_MAX=30
# RATE_LIMIT_USER_SENSITIVE_WINDOW_MS=60000
# RATE_LIMIT_HEAVY_MAX=10
# RATE_LIMIT_HEAVY_WINDOW_MS=60000
# RATE_LIMIT_PUBLIC_HEAVY_MAX=15
# RATE_LIMIT_PUBLIC_HEAVY_WINDOW_MS=60000

# CP-070 — Chiffrement credentials mail (AES-256-GCM) : 32 octets en hex (64 car.) ou base64
# MAIL_ENCRYPTION_KEY=

# CP-082 — Tracking ouverture / clic (opt-in RGPD : désactivé si absent ou false)
# MAIL_TRACKING_ENABLED=false
# URL publique absolue de l’API telle que vue depuis les clients mail (pixel + redirections)
# MAIL_TRACKING_PUBLIC_BASE_URL=https://api.example.com

# CP-085 — Journal optionnel des événements métier (system_events) pour audit / automatisations futures
# EVENT_LOG_ENABLED=false

# CP-FAR-008 DSM réel (far shading) — OFF par défaut
# HORIZON_DSM_ENABLED=false
# DSM_PROVIDER=AUTO
# DSM_MAX_TILES=500
# DSM_TILE_CACHE_TTL=2592000

# Pour activer DSM_REAL (LOCAL fixtures) — décommenter:
# HORIZON_DSM_ENABLED=true
# DSM_PROVIDER=LOCAL

# --- DSM HTTP GEOTIFF CONFIG (CP-FAR-C-05) ---
# Priorité dans computeMask : si DSM_PROVIDER_TYPE=HTTP_GEOTIFF + DSM_GEOTIFF_URL_TEMPLATE + DSM_ENABLE=true,
# le far shading consomme d'abord ce raster (même si DSM_PROVIDER=LOCAL pour les autres briques).
# Échec HTTP → RELIEF_ONLY traçable (meta.fallbackReason=HTTP_GEOTIFF_FAILED ou HTTP_GEOTIFF_MASK_FLAT, notes).
# Pour tests live: node backend/scripts/test-dsm-geotiff-live.js avec CP_FAR_C05_USE_HTTP_GEOTIFF=1
# HORIZON_DSM_ENABLED=true
# DSM_ENABLE=true
# DSM_PROVIDER_TYPE=HTTP_GEOTIFF
# DSM_GEOTIFF_URL_TEMPLATE=http://127.0.0.1:9876/{z}/{x}/{y}.tif
# --- Far horizon HD raycast (feature-flag safe, CP-FAR-IGN-06) ---
# FAR_HORIZON_HD_ENABLE=false
# FAR_HORIZON_HD_STEP_DEG=1
# FAR_HORIZON_HD_RADIUS_M=800
# FAR_HORIZON_HD_TIME_BUDGET_MS=3000

# --- OAuth Enedis (environnement local) ---
# ENEDIS_CLIENT_ID=
# ENEDIS_CLIENT_SECRET=
# ENEDIS_REDIRECT_URI=http://localhost:4000/api/enedis/callback
# ENEDIS_AUTH_URL=https://mon-compte-particulier.enedis.fr/oauth2/v3/authorize
# ENEDIS_TOKEN_URL=https://mon-compte-particulier.enedis.fr/oauth2/v3/token

# Pilotage charge — défaut legacy (35 % / 20 % / 10 % = 65 %). equipment_prudent = budget plafonné selon équipements déclarés.
# PILOTAGE_BUDGET_MODE=legacy
# PILOTAGE_BUDGET_MODE=equipment_prudent

# Reshape micro des équipements actuels sur courbe CSV (somme annuelle inchangée). 1/true = actif ; absent = inchangé (legacy).
# EQUIPMENT_CURRENT_RESHAPE_WITH_CSV=1
