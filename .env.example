# SolarGlobe CRM - Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs

# Base de données
DATABASE_URL=postgresql://user:password@localhost:5432/solarglobe

# JWT / Auth
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# API
API_V1_PREFIX=/api/v1

# Frontend (Vite) — clé publique Maps (Calpinage + DP). Restreindre par référent HTTP dans Google Cloud.
# Si la clé a fuité dans l’historique Git : en créer une nouvelle et révoquer l’ancienne.
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Logging (winston) — error | warn | info | debug
LOG_LEVEL=info

# --- DSM HTTP GEOTIFF CONFIG (masque horizon lointain) ---
# HORIZON_DSM_ENABLED=true
# DSM_ENABLE=true
# DSM_PROVIDER_TYPE=HTTP_GEOTIFF
# DSM_GEOTIFF_URL_TEMPLATE=<URL valide ou fixture locale, ex. http://127.0.0.1:9876/{z}/{x}/{y}.tif>
# FAR_HORIZON_HD_ENABLE=false
# FAR_HORIZON_HD_STEP_DEG=1
# FAR_HORIZON_HD_RADIUS_M=800
# FAR_HORIZON_HD_TIME_BUDGET_MS=3000
# Option fixture locale (sans serveur) : DSM_PROVIDER=LOCAL (pas d'URL requise)
